# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Bluesky credentials
BLUESKY_HANDLE=your.handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password-here

# Mastodon credentials
# Generate an access token at: https://your-instance/settings/applications
MASTODON_INSTANCE=mastodon.social
MASTODON_ACCESS_TOKEN=your-access-token-here

# X (Twitter) credentials
# Create an app at: https://developer.x.com/en/portal/dashboard
# Requires OAuth 1.0a User Context with read/write permissions
X_API_KEY=your-api-key-here
X_API_KEY_SECRET=your-api-key-secret-here
X_ACCESS_TOKEN=your-access-token-here
X_ACCESS_TOKEN_SECRET=your-access-token-secret-here
